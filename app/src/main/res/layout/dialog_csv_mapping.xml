<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Map CSV Columns"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Match the system fields to your CSV columns."
            android:textSize="14sp"
            android:textColor="@color/brand_on_surface_variant"
            android:layout_marginBottom="20dp" />

        <!-- Student ID Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student ID *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerStudentId"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Student Name Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerName"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Roll Number Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Roll Number *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerRollNumber"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Admission Number Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admission/Enrollment ID *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerAdmissionNumber"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Class Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Class/Grade *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerClass"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Section Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Section *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerSection"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- School Code Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="School Code"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(If missing, will default to active school)"
            android:textSize="11sp"
            android:textColor="@color/brand_on_surface_variant"
            android:layout_marginTop="2dp" />
        <Spinner
            android:id="@+id/spinnerSchoolCode"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Parent Mobile Mapping -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Parent Contact/Mobile *"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary" />
        <Spinner
            android:id="@+id/spinnerParentMobile"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_spinner" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/brand_on_surface_variant"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Confirm &amp; Parse"
                android:backgroundTint="@color/brand_primary"
                android:textColor="@color/brand_white"
                app:cornerRadius="24dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
