<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_background">

    <!-- Header / Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_bottom_gradient"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Photo Viewer"
            app:titleTextColor="@color/brand_white"
            app:titleCentered="true"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/brand_white"
            app:elevation="0dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_primary"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdmissionNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admission No: 0000"
            android:textSize="15sp"
            android:textColor="@color/brand_on_surface_variant"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvClassSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Class: 10A - Section: A"
            android:textSize="14sp"
            android:textColor="@color/brand_on_surface_variant"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRollNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Roll No: 001"
            android:textSize="14sp"
            android:textColor="@color/brand_on_surface_variant"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSchoolCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="School: SCH01"
            android:textSize="14sp"
            android:textColor="@color/brand_on_surface_variant"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="260dp"
            android:layout_height="320dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/brand_outline"
            app:cardBackgroundColor="@color/brand_surface">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Download Photo"
            android:backgroundTint="@color/brand_secondary"
            android:textColor="@color/brand_white"
            app:cornerRadius="28dp"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>
